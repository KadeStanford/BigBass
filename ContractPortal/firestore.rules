rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: check if the user is an email-authenticated admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email != null;
    }

    // Admin settings — only email-authenticated admins
    match /settings/{document=**} {
      allow read, write: if isAdmin();
    }

    // Contracts — only email-authenticated admins can read/list.
    // Anonymous users can update ONLY specific fields during signing flow.
    match /contracts/{contractId} {
      allow read, create, delete: if isAdmin();
      allow update: if isAdmin();
      // Allow anonymous signing users to update status (viewed → signed)
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "signedAt", "signedPdfUrl", "signatureData", "viewedAt"])
        && request.resource.data.status in ["viewed", "signed"]
        && resource.data.status in ["sent", "viewed"];
    }

    // Signing tokens — only the specific token is readable by authenticated users,
    // not the entire collection. Admin can create/delete. Auth users can update status only.
    match /signing/{token} {
      allow read: if request.auth != null;
      allow create, delete: if isAdmin();
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "signatureData", "signedAt"]);
    }

    // Invoices — only email-authenticated admins
    match /invoices/{invoiceId} {
      allow read, write: if isAdmin();
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
