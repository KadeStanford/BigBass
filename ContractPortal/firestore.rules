rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admin settings — only authenticated users can read/write
    match /settings/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Contracts — only email-authenticated admins
    match /contracts/{contractId} {
      allow read, write: if request.auth != null && request.auth.token.email != null;
      // Allow anonymous users to update status (viewed/signed) if they know the contract ID
      allow update: if request.auth != null
        && request.resource.data.status in ["viewed", "signed"]
        && resource.data.status in ["sent", "viewed"];
    }

    // Signing tokens — readable by any authenticated user (including anonymous)
    // Writable (create/delete) only by admins; update by any auth user
    match /signing/{token} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null && request.auth.token.email != null;
      allow update: if request.auth != null;
    }

    // Invoices — only email-authenticated admins
    match /invoices/{invoiceId} {
      allow read, write: if request.auth != null && request.auth.token.email != null;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
