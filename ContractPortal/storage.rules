rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper: check if the user is an email-authenticated admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email != null;
    }

    // Contracts folder — admin-only read/write
    match /contracts/{fileName} {
      allow read, write: if isAdmin();
    }

    // Invoices folder — admin-only read/write
    match /invoices/{fileName} {
      allow read, write: if isAdmin();
    }

    // Signed contracts folder — any authenticated user can upload (for remote signing),
    // but only admins can read/download
    match /signed/{fileName} {
      allow write: if request.auth != null;
      allow read: if isAdmin();
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
